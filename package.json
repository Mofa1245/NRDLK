{
  "name": "qatar-business-ai-phone",
  "version": "1.0.0",
  "description": "Qatar Business AI Phone Agent — voice receptionist with booking/order capture and WhatsApp confirmation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dashboard:build": "npm --prefix dashboard run build",
    "dashboard:start": "npm --prefix dashboard run start",
    "deploy": "npm run build && npm run dashboard:build && pm2 start ecosystem.config.cjs --update-env",
    "prompt": "node dist/cli/build-prompt.js",
    "health": "node dist/cli/health-cron.js",
    "integration:test": "npm run build && node dist/dev/integration-test.js",
    "smoke:test": "npm run build && node dist/dev/smoke-test.js",
    "acceptance:test": "npm run build && node dist/dev/acceptance-matrix.js",
    "voice:start": "npm run build && node dist/server.js"
  },
  "keywords": [
    "voice-agent",
    "qatar",
    "booking",
    "whatsapp"
  ],
  "license": "MIT",
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.33",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.34.0",
    "twilio": "^5.13.1",
    "ws": "^8.20.0"
  }
}
